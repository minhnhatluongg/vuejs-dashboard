# Copy file này thành .env hoặc .env.local rồi điền giá trị thật.
# KHÔNG commit file .env / .env.local thật lên git!

# Supabase project URL (lấy ở Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon (public) key — an toàn dùng ở client KHI đã bật RLS
VITE_SUPABASE_ANON_KEY=your-anon-key-here
